		{"id":"9e3a28babef74f12","x":-480,"y":-2580,"width":980,"height":420,"type":"text","text":"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\n\n[System.Environment]::SetEnvironmentVariable(\"ANTHROPIC_AUTH_TOKEN\", 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\n\n\nOPENROUTER\n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\n\n\n[System.Environment]::SetEnvironmentVariable(\"ANTHROPIC_BASE_URL\", \"https://openrouter.ai/api/v1\", \"User\")\n[System.Environment]::SetEnvironmentVariable(\"ANTHROPIC_AUTH_TOKEN\",  \"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\"\n[System.Environment]::SetEnvironmentVariable(\"ANTHROPIC_API_KEY\", \"\", \"User\")\n[System.Environment]::SetEnvironmentVariable(\"ANTHROPIC_MODEL\", \"openrouter/auto\", \"User\")\n\n\nOPENROUTER\n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"},
		{"id":"6de64b7b31fcaa55","x":-480,"y":-2120,"width":980,"height":1020,"type":"text","text":"$env:ANTHROPIC_BASE_URL=\"https://openrouter.ai/api\"\n$env:ANTHROPIC_AUTH_TOKEN=\"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\"\n$env:ANTHROPIC_MODEL=\"google/gemini-2.5-pro\"\n$env:ANTHROPIC_SMALL_FAST_MODEL=\"google/gemini-2.5-flash\"\n$env:ANTHROPIC_FALLBACK_MODEL=\"openrouter/free\"\n$env:ANTHROPIC_API_KEY=\"\"\n\n\n# OpenRouter backend\n$env:ANTHROPIC_BASE_URL = \"https://openrouter.ai/api\"\n$env:ANTHROPIC_AUTH_TOKEN = \"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\"\n\n# Primary model (quality)\n$env:ANTHROPIC_MODEL = \"google/gemini-2.5-pro\"\n\n# Fast model (speed + glue tasks)\n$env:ANTHROPIC_SMALL_FAST_MODEL = \"google/gemini-2.5-flash\"\n\n# Fallback (resilience)\n$env:ANTHROPIC_FALLBACK_MODEL = \"openrouter/free\"\n\n# Safety: block Anthropic billing\n$env:ANTHROPIC_API_KEY = \"\"\n``\n\n$env:ANTHROPIC_BASE_URL = \"https://openrouter.ai/api\"\n$env:ANTHROPIC_AUTH_TOKEN = \"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\"\n$env:ANTHROPIC_MODEL = \"google/gemini-2.5-pro\"\n$env:ANTHROPIC_SMALL_FAST_MODEL = \"google/gemini-2.5-flash\"\n$env:ANTHROPIC_FALLBACK_MODEL = \"openrouter/free\"\n$env:ANTHROPIC_API_KEY = \"\""},
		{"id":"b75afb6609024018","x":-480,"y":-908,"width":980,"height":728,"type":"text","text":"function claude-best {\n    $env:ANTHROPIC_BASE_URL = \"https://openrouter.ai/api\"\n    $env:ANTHROPIC_AUTH_TOKEN = \"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\"\n\n    $env:ANTHROPIC_MODEL = \"google/gemini-2.5-pro\"\n    $env:ANTHROPIC_SMALL_FAST_MODEL = \"google/gemini-2.5-flash\"\n    $env:ANTHROPIC_FALLBACK_MODEL = \"openrouter/free\"\n\n    # Block Anthropic billing\n    $env:ANTHROPIC_API_KEY = \"\"\n\n    Write-Host \"✅ Claude ready: Gemini Pro + Flash + Free fallback\" -ForegroundColor Green\n}\n\nfunction claude-free {\n    $env:ANTHROPIC_BASE_URL = \"https://openrouter.ai/api\"\n    $env:ANTHROPIC_AUTH_TOKEN = \"sk-or-v1-YOUR_REAL_OPENROUTER_KEY\"\n\n    $env:ANTHROPIC_MODEL = \"openrouter/free\"\n    $env:ANTHROPIC_SMALL_FAST_MODEL = \"openrouter/free\"\n    $env:ANTHROPIC_FALLBACK_MODEL = \"openrouter/free\"\n\n    $env:ANTHROPIC_API_KEY = \"\"\n\n    Write-Host \"✅ Claude ready: Free-only mode\" -ForegroundColor Yellow\n}\n"},
		{"id":"2d8923ed1136b52d","x":-480,"y":-120,"width":980,"height":840,"type":"text","text":"# Check the server is running (no auth required)\ncurl -k https://127.0.0.1:27124/\n\n# List files at the root of your vault\ncurl -k -H \"Authorization: Bearer e3fdc66545a8788d035e15fca671b5e7f78dec36211ed04697673bb5e82d2c81\" \\\n  https://127.0.0.1:27124/vault/\n\n# Read a note\ncurl -k -H \"Authorization: Bearer e3fdc66545a8788d035e15fca671b5e7f78dec36211ed04697673bb5e82d2c81\" \\\n  https://127.0.0.1:27124/vault/path/to/note.md\n\n# Read a specific heading (URL-embedded target)\ncurl -k -H \"Authorization: Bearer e3fdc66545a8788d035e15fca671b5e7f78dec36211ed04697673bb5e82d2c81\" \\\n  https://127.0.0.1:27124/vault/path/to/note.md/heading/My%20Section\n\n# Append a line to a specific heading (PATCH with headers)\ncurl -k -X PATCH \\\n  -H \"Authorization: Bearer e3fdc66545a8788d035e15fca671b5e7f78dec36211ed04697673bb5e82d2c81\" \\\n  -H \"Operation: append\" \\\n  -H \"Target-Type: heading\" \\\n  -H \"Target: My Section\" \\\n  -H \"Content-Type: text/plain\" \\\n  --data \"New line of content\" \\\n  https://127.0.0.1:27124/vault/path/to/note.md"}
	],
